# ============================================================
#  AI Travel Companion — Environment Variables
#  Copy this file to backend/.env and fill in your values
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Choose: "openai" or "groq"
# Groq is FREE and fast — start here
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your-groq-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ── Web Search (REQUIRED for RAG) ────────────────────────────
# Tavily is purpose-built for AI agents — 1000 FREE searches/month
# Get key at: https://app.tavily.com (takes 30 seconds)
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── Embeddings for RAG vector search (Optional) ──────────────
# If set: uses semantic vector similarity for retrieval
# If not set: falls back to keyword search (still works great)
# Uses OPENAI_API_KEY above — no separate key needed

# ── Google APIs (Optional — real place data) ─────────────────
# Get from: https://console.cloud.google.com
# Enable: Places API, Distance Matrix API
GOOGLE_PLACES_KEY=your-google-places-key-here

# ── Weather API (Optional — free tier) ───────────────────────
# Free at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key-here

# ── App Config ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
SESSION_SECRET=change-this-to-any-random-string

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
